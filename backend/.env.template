# Local-only env vars for backend scripts. Copy to backend/.env and fill in.
# These are NOT used by deployed Edge Functions — those read from Supabase secrets.

# Dev project (always points to the dev/staging Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Prod project (only needed for scripts run with --prod)
PROD_SUPABASE_URL=
PROD_SUPABASE_SERVICE_ROLE_KEY=
